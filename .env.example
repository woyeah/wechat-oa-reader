# ============================================================
# Multi-MCP .env — each service uses its own prefix
# ============================================================

# ---------- WeCom MCP Server (wecom-mcp) ----------

# WeCom API (required)
WECOM_CORP_ID=
WECOM_AGENT_SECRET=
WECOM_AGENT_ID=

# WeCom callback (required for receiving messages)
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_ENCODING_AES_KEY=

# WeCom MCP server (optional, has defaults)
WECOM_MCP_HOST=0.0.0.0
WECOM_MCP_PORT=8000
WECOM_DB_PATH=/data/wecom.db

# ---------- Docker / Registry ----------

REGISTRY=192.168.50.135:5500
WECOM_MCP_TAG=latest

# ---------- Future MCP services ----------
# Copy the pattern above with a new prefix, e.g.:
# WECHAT_MCP_PORT=8001
# ZSXQ_MCP_PORT=8002
