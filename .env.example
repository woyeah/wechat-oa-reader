# ============================================================
# Shared config (used by docker-compose variable substitution)
# ============================================================

REGISTRY=192.168.50.135:5500
IMAGE_TAG=latest

# ============================================================
# Per-instance config — copy this block to .env.wecom-<name>
# e.g. .env.wecom-hr, .env.wecom-dev
# Each instance gets its own file, its own port, its own DB.
# NOTE: SQLite does not support concurrent writes — each instance
# MUST use a separate volume/DB file. Never share /data between instances.
# ============================================================

# WeCom API
WECOM_CORP_ID=
WECOM_AGENT_SECRET=
WECOM_AGENT_ID=

# WeCom API reverse proxy (optional, direct access if empty)
WECOM_PROXY_URL=
WECOM_PROXY_KEY=

# Callback (for receiving messages)
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_ENCODING_AES_KEY=

# MCP server
WECOM_DB_PATH=/data/wecom.db

# ============================================================
# .env (compose-level) — host port mapping per instance
# Docker compose ports can only read from .env, not env_file.
# Create .env alongside docker-compose.prod.yml:
#
#   WECOM_1_PORT=8002
#   WECOM_2_PORT=8003
# ============================================================
